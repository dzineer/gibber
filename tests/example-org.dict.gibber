---
id: EXAMPLE-ORG-DICT
gibber_dict: meta/v1
format: dict.gibber/1
---

;; A toy example of an organization-defined dictionary. Extends
;; meta/v1 with a handful of finance-specific symbols. Used by the
;; test suite to verify that inheritance works as expected.
;;
;; This is NOT a real dictionary — it exists to exercise the loader
;; on a small but nontrivial input.

(§dictionary
  §id:"example-org/v1"
  §version:"0.1.0"
  §description:"Toy finance-org dictionary for loader tests."
  §extends:["meta/v1"]
  §entries:[

    (§symbol §name:§wire-transfer
      §kind:§top-level-form
      §summary:"A wire transfer request."
      §fields:[
        (§field §name:§id §type:§string §required:true)
        (§field §name:§amount §type:§int §required:true)
        (§field §name:§currency §type:(§enum §usd §eur §gbp) §required:true)
        (§field §name:§recipient §type:(§ref §verified-contact) §required:true)
        (§field §name:§note §type:§string §required:false)])

    (§symbol §name:§verified-contact
      §kind:§nested-form
      §summary:"A contact that has passed KYC verification."
      §fields:[
        (§field §name:§id §type:§string §required:true)
        (§field §name:§kyc-verified-at §type:§string §required:true)
        (§field §name:§name §type:§string §required:false)])

    (§symbol §name:§usd §kind:§value §of-type:§currency §summary:"US dollar.")
    (§symbol §name:§eur §kind:§value §of-type:§currency §summary:"Euro.")
    (§symbol §name:§gbp §kind:§value §of-type:§currency §summary:"British pound.")
  ])
